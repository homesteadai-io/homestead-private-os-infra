# Homestead Private OS Infra v0

HOMESTEAD_ENV=local
HOMESTEAD_REPO_PATH=/workspace/keep
RECEIPTS_DIR=/data/receipts

# Mount the repo you want the API to inspect.
# On the Hetzner node this should usually be the checked-out Homestead/The Keep repo.
KEEP_REPO_HOST_PATH=/opt/homestead/the-keep
HOMESTEAD_DATA_HOST_PATH=/opt/homestead/data

# API/MCP internal URLs
HOMESTEAD_API_URL=http://homestead-api:8000
HOMESTEAD_MCP_URL=http://homestead-mcp:8010

# OpenRouter is stubbed in v0. Task 3 wires actual calls.
OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini

# Future tasks. Present as placeholders only; not used in v0.
LANGFUSE_PUBLIC_KEY=replace_later
LANGFUSE_SECRET_KEY=replace_later
LANGFUSE_HOST=https://cloud.langfuse.com
SMTP_HOST=replace_later
SMTP_PORT=587
SMTP_USER=agent@homesteadai.io
SMTP_PASSWORD=replace_later
SMTP_FROM=agent@homesteadai.io

