# Homestead Private OS Infra v0

HOMESTEAD_ENV=local
HOMESTEAD_REPO_PATH=/workspace/keep
RECEIPTS_DIR=/data/receipts

# Mount the repo you want the API to inspect.
# On the Hetzner node this should usually be the checked-out Homestead/The Keep repo.
KEEP_REPO_HOST_PATH=/opt/homestead/the-keep
HOMESTEAD_DATA_PATH=/opt/homestead/data

# Optional: Docker Compose service env_file path.
# Local default is infra/.env. Hetzner uses /opt/homestead/secrets/runtime.env.
HOMESTEAD_ENV_FILE=./.env

# API/MCP internal URLs
HOMESTEAD_API_URL=http://homestead-api:8000
HOMESTEAD_MCP_URL=http://homestead-mcp:8010

# Caddy bind addresses.
# Local default: loopback only.
# Tailscale-only server: set both to the server's Tailscale IP.
# Public DNS mode: set both to 0.0.0.0 only after accepting unauthenticated v0 exposure.
CADDY_HTTP_BIND=127.0.0.1
CADDY_HTTPS_BIND=127.0.0.1
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# OpenRouter powers /model/route. Keep real keys in local/server env files only.
OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
OPENROUTER_HTTP_REFERER=https://homesteadai.io
OPENROUTER_APP_TITLE="Homestead Private OS"

# Optional Langfuse tracing for /model/route. Disabled by default.
# Keep real keys in local/server env files only.
LANGFUSE_ENABLED=false
LANGFUSE_HOST=http://100.112.20.36:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_ENVIRONMENT=homestead-private-os
LANGFUSE_RELEASE=v0-openrouter-route

# Future tasks. Present as placeholders only; not used in v0.
SMTP_HOST=replace_later
SMTP_PORT=587
SMTP_USER=agent@homesteadai.io
SMTP_PASSWORD=replace_later
SMTP_FROM=agent@homesteadai.io
